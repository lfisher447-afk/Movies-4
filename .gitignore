# ═══════════════════════════════════════════════
# BingeBox Omega — .gitignore (Advanced)
# ═══════════════════════════════════════════════

# ── Dependencies ────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Environment & Secrets ───────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env
secrets.json
*.pem
*.key
*.crt
*.p12

# ── Build Output ────────────────────────────────
dist/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/
.turbo/
*.tsbuildinfo

# ── Logs ────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pm2*.log

# ── System & OS Files ───────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDE & Editor ────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace

# ── Testing & Coverage ──────────────────────────
coverage/
.nyc_output/
*.lcov
jest-results/
test-results/
playwright-report/
.playwright/

# ── Railway / Cloud Deploy ──────────────────────
.railway/
railway.lock

# ── Docker ──────────────────────────────────────
*.dockerfile
docker-compose.override.yml

# ── Misc ────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
.history/
.sessions/
*.pid
*.seed
*.pid.lock
*.map

# ── Analytics / Monitoring (local only) ─────────
newrelic_agent.log
