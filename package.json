{
  "name": "bingebox-omega-server",
  "version": "10.0.0",
  "description": "BingeBox Omega — Ultimate Cinematic Streaming Engine Server",
  "main": "server.js",
  "author": "BingeBox Omega",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js --watch '*.js' --ignore 'public/'",
    "dev:debug": "NODE_OPTIONS='--inspect' nodemon server.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules/",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "health": "node -e \"require('http').get('http://localhost:3000/health',r=>process.exit(r.statusCode===200?0:1))\"",
    "analyze": "node scripts/analyze.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop bingebox-omega",
    "pm2:logs": "pm2 logs bingebox-omega",
    "security:audit": "npm audit --audit-level=moderate",
    "prestart": "node -e \"console.log('[BingeBox] Node', process.version, '| Env:', process.env.NODE_ENV||'production')\"",
    "postinstall": "node -e \"console.log('[BingeBox] Dependencies ready.')\"",
    "railway:deploy": "railway up"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "eslint-config-node": "^4.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords":[
    "bingebox",
    "streaming",
    "movies",
    "tv-shows",
    "tmdb",
    "omega",
    "express",
    "railway"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bingebox/omega-server.git"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":[
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom":[
      "*.js",
      "!jest.config.js"
    ],
    "coverageDirectory": "coverage"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off",
      "prefer-const": "error",
      "no-var": "error",
      "eqeqeq":[
        "error",
        "always"
      ],
      "semi": [
        "error",
        "always"
      ]
    }
  },
  "nodemonConfig": {
    "watch":[
      "*.js",
      "middleware/"
    ],
    "ext": "js,json",
    "delay": "500"
  }
}
